---
import PageLayout from "../../layouts/PageLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<PageLayout
  title="Blog"
  description="HVAC tips, maintenance advice, and expert insights for Ottawa homeowners from Northern Elements HVAC."
>
  <!-- Hero -->
  <section class="bg-brand-700 py-16">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold text-white sm:text-4xl">HVAC Tips & Insights</h1>
      <p class="mt-4 text-lg text-brand-100">
        Expert advice to keep your Ottawa home comfortable year-round.
      </p>
    </div>
  </section>

  <!-- Posts -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.id}
              heroImage={post.data.heroImage}
            />
          ))
        }
      </div>
    </div>
  </section>
</PageLayout>
