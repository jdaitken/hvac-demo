---
import PageLayout from "../layouts/PageLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ServiceCard from "../components/ServiceCard.astro";
import Button from "../components/Button.astro";
import CTABanner from "../components/CTABanner.astro";
import site from "../data/site.json";
---

<PageLayout
  title="Services"
  description="Residential and commercial HVAC services in Ottawa. Furnace repair, AC installation, heat pumps, maintenance plans, and 24/7 emergency service."
>
  <!-- Hero -->
  <section class="bg-brand-700 py-16">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold text-white sm:text-4xl">Our HVAC Services</h1>
      <p class="mt-4 text-lg text-brand-100">
        Complete heating and cooling solutions for Ottawa homes and businesses.
      </p>
    </div>
  </section>

  <!-- Residential -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        subtitle="Keep your family comfortable with expert residential HVAC services."
        align="left"
      >
        Residential Services
      </SectionHeading>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <ServiceCard
          title="Furnace Repair & Installation"
          description="Expert diagnosis and repair for all furnace makes and models. We also install high-efficiency furnaces to keep your energy bills low."
          icon='<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z" /></svg>'
        />
        <ServiceCard
          title="Air Conditioning"
          description="From central AC installation to ductless mini-splits, we have cooling solutions for every Ottawa home."
          icon='<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>'
        />
        <ServiceCard
          title="Heat Pumps"
          description="Energy-efficient heat pump installation and service. Heat and cool your home with one system."
          icon='<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>'
        />
        <ServiceCard
          title="Duct Cleaning & Repair"
          description="Improve your indoor air quality and system efficiency with professional duct cleaning and sealing."
          icon='<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>'
        />
        <ServiceCard
          title="Smart Thermostats"
          description="Upgrade to a programmable or smart thermostat and save up to 20% on your energy bills."
          icon='<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>'
        />
        <ServiceCard
          title="Maintenance Plans"
          description="Annual tune-ups that extend equipment life, prevent breakdowns, and keep warranties valid."
          icon='<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>'
        />
      </div>
    </div>
  </section>

  <!-- Commercial -->
  <section class="bg-neutral-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        subtitle="Reliable HVAC solutions tailored for Ottawa businesses and commercial properties."
        align="left"
      >
        Commercial Services
      </SectionHeading>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <ServiceCard
          title="Commercial HVAC Installation"
          description="Custom-designed heating and cooling systems for offices, retail, restaurants, and warehouses."
          icon='<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>'
        />
        <ServiceCard
          title="Preventative Maintenance Contracts"
          description="Scheduled maintenance programs that minimize downtime and keep your business comfortable year-round."
          icon='<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>'
        />
        <ServiceCard
          title="Rooftop Unit Service"
          description="Installation, repair, and maintenance of commercial rooftop HVAC units and package systems."
          icon='<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>'
        />
      </div>
    </div>
  </section>

  <!-- Emergency highlight -->
  <section class="bg-accent-500 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center text-center md:flex-row md:justify-between md:text-left">
        <div class="max-w-2xl">
          <h2 class="text-3xl font-bold text-white">24/7 Emergency HVAC Service</h2>
          <p class="mt-3 text-lg text-accent-100">
            Furnace failure in the middle of an Ottawa winter can be dangerous. Our emergency
            technicians are available around the clock — including holidays and weekends.
            Call now for immediate dispatch.
          </p>
        </div>
        <div class="mt-6 md:mt-0 md:ml-8">
          <a
            href={`tel:${site.phoneRaw}`}
            class="inline-flex items-center gap-2 rounded-lg bg-white px-8 py-4 text-lg font-bold text-accent-600 shadow-lg transition-colors hover:bg-neutral-100"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"></path>
            </svg>
            {site.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Winter seasonal section -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <SectionHeading align="left" subtitle="Ottawa winters demand a reliable heating system. Don't wait until it's too late.">
            Winter Heating Season
          </SectionHeading>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-brand-500" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-neutral-700"><strong class="text-neutral-900">Pre-season furnace inspections</strong> to catch problems before the cold hits</span>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-brand-500" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-neutral-700"><strong class="text-neutral-900">Same-day furnace repairs</strong> when your heat goes out unexpectedly</span>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-brand-500" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-neutral-700"><strong class="text-neutral-900">High-efficiency furnace upgrades</strong> that lower your energy bills</span>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-brand-500" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-neutral-700"><strong class="text-neutral-900">Carbon monoxide testing</strong> to keep your family safe</span>
            </li>
          </ul>
          <div class="mt-8">
            <Button href="/contact">Schedule a Winter Tune-Up</Button>
          </div>
        </div>
        <div>
          <img
            src="https://images.unsplash.com/photo-1513694203232-719a280e022f?w=600&h=400&fit=crop"
            alt="Cozy Ottawa home in winter"
            class="rounded-xl shadow-lg"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner />
</PageLayout>
