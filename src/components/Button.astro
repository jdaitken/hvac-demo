---
interface Props {
  variant?: "primary" | "accent" | "outline" | "white";
  href?: string;
  type?: "button" | "submit";
  class?: string;
}

const { variant = "primary", href, type, class: className } = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 rounded-lg px-6 py-3 font-semibold transition-colors duration-200 text-center";

const variants: Record<string, string> = {
  primary: "bg-brand-500 text-white hover:bg-brand-600",
  accent: "bg-accent-500 text-white hover:bg-accent-600",
  outline: "border-2 border-brand-500 text-brand-500 hover:bg-brand-50",
  white: "bg-white text-brand-700 hover:bg-neutral-100",
};

const classes = `${base} ${variants[variant]} ${className ?? ""}`;
const Tag = href ? "a" : "button";
---

<Tag href={href} type={!href ? type : undefined} class={classes}>
  <slot />
</Tag>
