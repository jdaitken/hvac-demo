---
import site from "../data/site.json";

const navLinks = [
  { label: "Home", href: "/" },
  { label: "Services", href: "/services" },
  { label: "About", href: "/about" },
  { label: "Blog", href: "/blog" },
  { label: "Contact", href: "/contact" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-neutral-200 bg-white/95 backdrop-blur-sm">
  <!-- Top bar -->
  <div class="hidden bg-brand-700 px-4 py-2 text-sm text-white sm:block">
    <div class="mx-auto flex max-w-7xl items-center justify-between">
      <span>{site.hours.emergency}</span>
      <a href={`tel:${site.phoneRaw}`} class="font-semibold hover:text-accent-300 transition-colors">
        {site.phone}
      </a>
    </div>
  </div>

  <!-- Main nav -->
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2 text-xl font-bold text-brand-600">
      <!-- Flame (heating) -->
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M13.5 1.515a3 3 0 00-3 0L3 5.845a3 3 0 00-1.5 2.598V15.75a3 3 0 001.5 2.598l7.5 4.33a3 3 0 003 0l7.5-4.33a3 3 0 001.5-2.598V8.443a3 3 0 00-1.5-2.598L13.5 1.515z" fill="none"/>
        <path d="M12 2C9.5 5 8 8 9 11c-2-1-3-3.5-2.5-6C4 7 3 10 4 13c1 3.5 4.5 6 8 6s7-2.5 8-6c1-3-0.5-6.5-3-8.5C17.5 7 17 9 15.5 10c1-2.5.5-5.5-3.5-8z"/>
      </svg>
      <span>
        <span class="text-brand-500">Northern Elements</span>
        <span class="text-accent-500 font-extrabold">HVAC</span>
      </span>
      <!-- Wave (cooling) -->
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-400" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M3 7c1.5 0 2.5 1 4 1s2.5-1 4-1 2.5 1 4 1 2.5-1 4-1M3 12c1.5 0 2.5 1 4 1s2.5-1 4-1 2.5 1 4 1 2.5-1 4-1M3 17c1.5 0 2.5 1 4 1s2.5-1 4-1 2.5 1 4 1 2.5-1 4-1" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
      </svg>
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-8 md:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class={`text-sm font-medium transition-colors hover:text-brand-500 ${
              currentPath === link.href ? "text-brand-500" : "text-neutral-700"
            }`}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={`tel:${site.phoneRaw}`}
        class="inline-flex items-center gap-2 rounded-lg bg-accent-500 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-accent-600"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path
            d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"
          ></path>
        </svg>
        {site.phone}
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="flex items-center md:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6 text-neutral-700"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-neutral-200 bg-white md:hidden">
    <div class="space-y-1 px-4 py-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class={`block rounded-lg px-3 py-2 text-base font-medium transition-colors hover:bg-neutral-50 ${
              currentPath === link.href
                ? "text-brand-500 bg-brand-50"
                : "text-neutral-700"
            }`}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={`tel:${site.phoneRaw}`}
        class="mt-2 flex items-center justify-center gap-2 rounded-lg bg-accent-500 px-4 py-3 text-base font-semibold text-white"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path
            d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"
          ></path>
        </svg>
        Call {site.phone}
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const expanded = btn.getAttribute("aria-expanded") === "true";
    btn.setAttribute("aria-expanded", String(!expanded));
    menu?.classList.toggle("hidden");
  });
</script>
