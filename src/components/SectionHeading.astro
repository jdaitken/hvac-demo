---
interface Props {
  subtitle?: string;
  align?: "left" | "center";
}

const { subtitle, align = "center" } = Astro.props;
const alignment = align === "center" ? "text-center" : "text-left";
---

<div class={`mb-12 ${alignment}`}>
  <h2 class="text-3xl font-bold text-neutral-900 sm:text-4xl">
    <slot />
  </h2>
  {subtitle && <p class="mt-4 text-lg text-neutral-600">{subtitle}</p>}
</div>
