---
import Button from "./Button.astro";
import site from "../data/site.json";

interface Props {
  heading?: string;
  text?: string;
}

const {
  heading = "Ready for a Free Estimate?",
  text = "Contact us today for fast, reliable HVAC service in Ottawa and surrounding areas.",
} = Astro.props;
---

<section class="bg-brand-600 py-16">
  <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-white sm:text-4xl">{heading}</h2>
    <p class="mt-4 text-lg text-brand-100">{text}</p>
    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <Button variant="accent" href={`tel:${site.phoneRaw}`}>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path
            d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"
          ></path>
        </svg>
        Call {site.phone}
      </Button>
      <Button variant="white" href="/contact">Request a Quote</Button>
    </div>
  </div>
</section>
